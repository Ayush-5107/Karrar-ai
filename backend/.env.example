# Backend Environment Variables for Render
# Add these in the Render Dashboard > Your Service > Environment

# One dedicated OpenRouter key per agent
OPENROUTER_API_KEY_RISK=your_risk_key_here
OPENROUTER_API_KEY_EXPLAIN=your_explain_key_here
OPENROUTER_API_KEY_COUNTER=your_counter_key_here
OPENROUTER_API_KEY_GLOBAL=your_global_key_here
OPENROUTER_API_KEY_COMPLIANCE=your_compliance_key_here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
